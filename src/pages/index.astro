---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import heroImageDark from "../images/about-me-dark.jpg";
import heroImageLight from "../images/about-me-light.jpg";
import FeaturedArticles from "../components/articles/FeaturedArticles.astro";
import Projects from "../components/Projects.astro";

---

<BaseLayout>
	<!-- Hero section -->
	<div class="mx-auto lg:max-w-4xl mt-40 mb-20">
		<div class="flex flex-col lg:flex-row lg:items-center lg:space-x-16">
			<div>
				<p class="font-mono text-xs uppercase tracking-widest text-primary-700 dark:text-primary-300 mb-4">QA Engineer | API & UI Testing · Automation</p>
				<h1
					class="text-3xl sm:text-5xl font-bold tracking-tight text-balance"
				>
					Anna Szczęch
				</h1>
				<div class="mt-8 leading-8">
					<p>
						Passionate about API testing, test architecture, observability,
						and shifting quality left — ensuring defects are caught early,
						not when clients report them.
					</p>
				</div>
			</div>

			<div class="order-first lg:order-last flex-shrink-0 mb-8">

				<Image
					src={heroImageLight}
					alt="Anna Szczęch"
					class="block dark:hidden  rounded-full  size-20 lg:size-[250px] object-cover ring-1 ring-slate-400/30 shadow"
				/>
				<Image
					src={heroImageDark}
					alt="Anna Szczęch"
					class="hidden dark:block rounded-full size-20 lg:size-[250px] object-cover ring-1 ring-slate-400/30 shadow"
				/>
			</div>
		</div>
	</div>

	<!-- Featured articles -->
	<div class="mx-auto lg:max-w-4xl my-16 sm:my-30">
		<h2
			class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20"
		>
			Featured articles
		</h2>
		<FeaturedArticles />
	</div>

	<!-- Domain knowledge -->
	<div class="mx-auto lg:max-w-4xl my-16 sm:my-30">
		<h2 class="text-2xl sm:text-4xl font-bold tracking-tight mb-4">
			Domain knowledge
		</h2>
		<p class="text-slate-500 dark:text-slate-400 mb-10 sm:mb-20">Industries I've worked in</p>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">🛒</div>
				<h3 class="font-semibold mb-2">E-commerce</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Saleor — headless, GraphQL-first commerce platform. Payments (Adyen, Stripe, Mollie), taxes (Avatax), orders, checkout, shipping. <br> Frisco — online grocery with home delivery.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">💳</div>
				<h3 class="font-semibold mb-2">Fintech</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Vyze (acquired by Mastercard) — deferred payment platform connecting merchants with lenders.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">🏠</div>
				<h3 class="font-semibold mb-2">IoT / Smart Home</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">React Native app for iOS & Android smart home control. Sole QA owning the full testing lifecycle.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">📦</div>
				<h3 class="font-semibold mb-2">GS1 / Product Catalog</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Product catalogs and GTIN number verification systems — data integrity and standards compliance.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">⚖️</div>
				<h3 class="font-semibold mb-2">Legal Tech</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">BigHand — technology solutions for legal professionals. Document workflows, data insights, and tools to increase value and efficiency for law firms.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">🚗</div>
				<h3 class="font-semibold mb-2">Automotive</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">ERP systems and e-commerce parts catalogs for automotive industry. BMW motorcycle configurator and test ride booking.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">🚚</div>
				<h3 class="font-semibold mb-2">Transport & Logistics</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Web application for TLS industry — driver information system for warehouse halls: loading docks, ramp counts, and loading/unloading requirements.</p>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5">
				<div class="text-2xl mb-3">🛡️</div>
				<h3 class="font-semibold mb-2">Insurance</h3>
				<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Agent-facing application for insurance sales. Policy simulations, premium calculations, client data management, and document generation.</p>
			</div>
		</div>
	</div>

	<!-- Projects -->
	<div class="mx-auto lg:max-w-4xl my-16 sm:my-30">
		<h2
			class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20"
		>
			Projects
		</h2>
		<Projects />
	</div>

</BaseLayout>
