---
const projects = [
	{
		icon: "🤖",
		title: "QA x AI Showcase",
		description:
			"A QA framework for Saleor Commerce designed and scaffolded with Claude Code — from strategy and ADRs to a unified Playwright toolchain covering API, UI, and accessibility testing.",
		link: "https://github.com/szczecha/saleor-qa-ai-showcase",
		linkText: "View Repository",
		external: true,
	},
	{
		icon: "📮",
		title: "Saleor Postman Collection",
		description:
			"Built originally for my own testing needs, then published to the community. Now used daily by developers worldwide — reduces time-to-first-API-call and accelerates integrations at scale.",
		link: "/blog/saleor-postman-collection",
		linkText: "View Details",
	},
	{
		icon: "📝",
		title: "Saleor Documentation",
		description:
			"Led a documentation initiative targeting highest-priority gaps from real customer questions. Covers orders lifecycle, warehouse & shipping, bulk API operations, webhook troubleshooting and cloud environment management.",
		link: "https://github.com/saleor/saleor-docs/pulls?q=is%3Apr+is%3Aclosed+author%3Aszczecha",
		linkText: "View PRs",
		external: true,
	},
	{
		icon: "🧪",
		title: "Saleor Core — Test & Quality Contributions",
		description:
			"API regression tests. Sample database overhaul with richer product attributes and Transaction API coverage.",
		link: "https://github.com/saleor/saleor/pulls?q=is%3Apr+is%3Aclosed+author%3Aszczecha",
		linkText: "View PRs",
		external: true,
	},
	{
		icon: "🖥️",
		title: "Saleor Dashboard — UI Contributions",
		description:
			"Contributions to Saleor's GraphQL-powered dashboard application — increasing test coverage, fixing flaky tests, and resolving CI/CD issues.",
		link: "https://github.com/saleor/saleor-dashboard/pulls?q=is%3Apr+author%3Aszczecha+is%3Aclosed",
		linkText: "View PRs",
		external: true,
	},
];
---

<div
	class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-14 gap-y-10 md:gap-y-18"
>
	{
		projects.map((project, index) => (
			<div class="flex flex-col h-full text-sm relative group">
				{project.icon && <div class="text-3xl mb-5">{project.icon}</div>}
				<h2 class="font-semibold text-lg mb-2">
					<div class="absolute -inset-x-3 md:-inset-x-5 -inset-y-4 rounded-lg opacity-0 scale-75 group-hover:scale-100 group-hover:opacity-100 bg-slate-50 z-0 transition dark:bg-slate-800" />
					<a href={project.link} target={project.external ? "_blank" : undefined} rel={project.external ? "noopener noreferrer" : undefined}>
						<span class="absolute -inset-x-3 md:-inset-x-5 -inset-y-4 rounded-lg z-10" />
						<span class="relative">{project.title}</span>
					</a>
				</h2>
				<p class="relative leading-7 text-slate-700 dark:text-slate-300 flex-1">
					{project.description}
				</p>
				<p class="relative flex items-center space-x-1 text-slate-500 group-hover:text-primary-700 dark:group-hover:text-primary-300 mt-5">
					<span>{project.linkText} →</span>
				</p>
			</div>
		))
	}
</div>
