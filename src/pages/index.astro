---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import heroImageDark from "../images/about-me-dark.jpg";
import heroImageLight from "../images/about-me-light.jpg";
import FeaturedArticles from "../components/articles/FeaturedArticles.astro";
import Projects from "../components/Projects.astro";

---

<BaseLayout>
	<!-- Hero section -->
	<div class="mx-auto lg:max-w-4xl mt-40 mb-20">
		<div class="flex flex-col lg:flex-row lg:items-center lg:space-x-16">
			<div>
				<p class="font-mono text-xs uppercase tracking-widest text-primary-500 mb-4">QA Engineer · API & Automation Specialist</p>
				<h1
					class="text-3xl sm:text-5xl font-bold tracking-tight text-balance"
				>
					Anna Szczęch
				</h1>
				<div class="mt-8 leading-8">
					<p>
						10+ years delivering quality in complex, distributed systems.
						Passionate about API testing, test architecture, observability,
						and shifting quality left — ensuring defects are caught early,
						not when clients report them.
					</p>
				</div>
			</div>

			<div class="order-first lg:order-last flex-shrink-0 mb-8">

				<Image
					src={heroImageLight}
					alt="Anna Szczęch"
					class="block dark:hidden  rounded-full  size-20 lg:size-[350px] object-cover ring-1 ring-slate-400/30 shadow"
				/>
				<Image
					src={heroImageDark}
					alt="Anna Szczęch"
					class="hidden dark:block rounded-full size-20 lg:size-[350px] object-cover ring-1 ring-slate-400/30 shadow"
				/>
			</div>
		</div>
	</div>

	<!-- Featured articles -->
	<div class="mx-auto lg:max-w-4xl my-16 sm:my-30">
		<h2
			class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20"
		>
			Featured articles
		</h2>
		<FeaturedArticles />
	</div>

	<!-- Projects -->
	<div class="my-16 sm:my-30">
		<div class="mx-auto lg:max-w-4xl">
			<h2
				class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20"
			>
				Projects
			</h2>
		</div>

		<div class="mx-auto lg:max-w-5xl">
			<Projects />
		</div>
	</div>

</BaseLayout>
