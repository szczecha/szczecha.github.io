---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import Social from "../components/Social.astro";
import { Icon } from "astro-icon/components";

// SEO properties
const title = "About";
const description = "QA Engineer & Customer Enablement Specialist — 10+ years delivering quality in complex, distributed systems.";
---

<BaseLayout title={title} description={description}>
	<div class="flex gap-16 items-start">

		<!-- Main content -->
		<div class="flex-1 min-w-0">

			<div class="max-w-2xl lg:max-w-4xl">
				<header class="max-w-2xl">
					<h1 class="text-4xl md:text-6xl font-black tracking-tight mb-8">
						About
					</h1>
				</header>

				<section class="max-w-2xl">
					<div class="space-y-8 leading-8">
						<p>
							I'm a QA Engineer and Customer Enablement Specialist with 10+ years of experience
							delivering quality in complex, distributed systems. I've owned testing end-to-end
							across UI, API, and mobile — building frameworks from scratch, designing CI/CD-integrated
							test suites, and setting up observability dashboards.
						</p>
						<p>
							Most recently I've been working at Saleor Commerce, first as a QA Engineer and now
							in Customer Enablement — helping developers integrate with a headless, GraphQL-first
							commerce platform. I love being at the intersection of quality, developer experience,
							and technical communication.
						</p>
						<p>
							I thrive in product companies that take quality seriously — teams where I can
							collaborate closely with developers, share ideas, and build better software together.
							I'm open to QA Engineer, Quality Engineer, and SDET roles.
						</p>
					</div>

					<div class="sm:flex sm:items-center sm:justify-between space-y-4 sm:space-y-0 my-10">
						<div class="flex items-center space-x-4">
							<Social />
						</div>
					</div>
				</section>

				<section id="career" class="my-16 sm:my-30">
					<h2 class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20">
						Career
					</h2>
					<div>
						<Timeline />
					</div>
				</section>
			</div>

			<div id="education" class="max-w-4xl my-16 sm:my-30">
				<h2 class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20">
					Learning path
				</h2>
				<div class="space-y-4 mb-10">
					<div class="flex items-start gap-4 p-5 bg-slate-50 dark:bg-slate-800 rounded-xl">
						<span class="font-mono text-xs text-primary-500 whitespace-nowrap pt-0.5 min-w-[36px]">2026</span>
						<div>
							<h3 class="font-semibold text-sm mb-1">AI Testers — Accelerate automation with AI</h3>
							<p class="text-sm text-slate-600 dark:text-slate-400">aitesters.pl · Playwright + AI + MCP · In progress</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-5 bg-slate-50 dark:bg-slate-800 rounded-xl">
						<span class="font-mono text-xs text-primary-500 whitespace-nowrap pt-0.5 min-w-[36px]">2022</span>
						<div>
							<h3 class="font-semibold text-sm mb-1">Security in Software Testing</h3>
							<p class="text-sm text-slate-600 dark:text-slate-400">niebezpiecznik.pl · OWASP Top 10, Burp Suite Professional</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-5 bg-slate-50 dark:bg-slate-800 rounded-xl">
						<span class="font-mono text-xs text-primary-500 whitespace-nowrap pt-0.5 min-w-[36px]">2020</span>
						<div>
							<h3 class="font-semibold text-sm mb-1">CI/CD in the Cloud — GitLab CI</h3>
							<p class="text-sm text-slate-600 dark:text-slate-400">jaktestowac.pl · Building CI pipelines for automated tests</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-5 bg-slate-50 dark:bg-slate-800 rounded-xl">
						<span class="font-mono text-xs text-primary-500 whitespace-nowrap pt-0.5 min-w-[36px]">2017</span>
						<div>
							<h3 class="font-semibold text-sm mb-1">Web Application Testing</h3>
							<p class="text-sm text-slate-600 dark:text-slate-400">testerzy.pl · HTTP, HTML, CSS, XML, web testing tools</p>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div class="p-5 bg-slate-50 dark:bg-slate-800 rounded-xl">
						<p class="font-mono text-xs text-slate-400 mb-2">2011 — 2017</p>
						<h3 class="font-semibold mb-1">BSc Computer Engineering</h3>
						<p class="text-sm text-slate-600 dark:text-slate-400">Rzeszów University of Technology</p>
						<p class="text-xs text-slate-400 mt-1">Specialty: Information Technology in Enterprise</p>
					</div>
					<div class="p-5 bg-slate-50 dark:bg-slate-800 rounded-xl flex flex-col justify-center">
						<p class="font-mono text-xs text-slate-400 mb-2">Languages</p>
						<p class="font-semibold">Polish <span class="font-normal text-sm text-slate-500">— native</span></p>
						<p class="font-semibold mt-1">English <span class="font-normal text-sm text-slate-500">— communicative (B2)</span></p>
					</div>
				</div>
			</div>

			<div id="hobbies" class="max-w-4xl my-16 sm:my-30">
				<h2 class="text-2xl sm:text-4xl font-bold tracking-tight mb-10 sm:mb-20">
					When I'm not testing
				</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6">
						<div class="text-3xl mb-3">🏔️</div>
						<h3 class="font-semibold mb-2">Mountains & Outdoors</h3>
						<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
							Hiking, kayaking rivers, cycling, and rollerblading.
							Active life in fresh air is non-negotiable.
						</p>
					</div>
					<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6">
						<div class="text-3xl mb-3">🌿</div>
						<h3 class="font-semibold mb-2">Plants & Bamboo Garden</h3>
						<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
							Houseplant collector — sansevieria, philodendron, epipremnum varieties.
						</p>
					</div>
					<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6">
						<div class="text-3xl mb-3">🍝</div>
						<h3 class="font-semibold mb-2">Italian Cooking</h3>
						<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
							Classic Italian — carbonara, amatriciana, ragù alla bolognese.
							Sourdough bread baking.
						</p>
					</div>
					<div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6">
						<div class="text-3xl mb-3">🎲</div>
						<h3 class="font-semibold mb-2">Board Games</h3>
						<p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
							Settlers of Catan enthusiast. Strategy, trade, and a healthy dose of competitive spirit.
						</p>
					</div>
				</div>
			</div>

		</div>
	</div>
</BaseLayout>

<script>
	const sections = ["career", "education", "hobbies"];

	function updateActiveLink() {
		let current = "";
		for (const id of sections) {
			const el = document.getElementById(id);
			if (el && el.getBoundingClientRect().top <= 120) {
				current = id;
			}
		}
		document.querySelectorAll(".toc-link").forEach((link) => {
			const href = link.getAttribute("href");
			if (href === `#${current}`) {
				link.classList.add("text-primary-500", "font-medium");
				link.classList.remove("text-slate-500");
			} else {
				link.classList.remove("text-primary-500", "font-medium");
				link.classList.add("text-slate-500");
			}
		});
	}

	window.addEventListener("scroll", updateActiveLink, { passive: true });
	updateActiveLink();
</script>
